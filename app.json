{
  "expo": {
    "name": "Souq Qalqilya",
    "slug": "souq-qalqilya",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/images/plankton-logo.png",
    "scheme": "souqqalqilya",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.onspace.souq_qalqilya",
      "buildNumber": "6",
      "infoPlist": {
        "NSCameraUsageDescription": "Souq Qalqilya needs camera access to let you photograph items you want to sell. When you create or edit a marketplace listing, you can take a photo directly with your camera to attach as a product image so buyers can see exactly what you are offering.",
        "NSPhotoLibraryUsageDescription": "Souq Qalqilya needs access to your photo library so you can choose existing photos of items you want to sell or select a profile picture. Chosen images are uploaded to your listing or profile so other users can see them.",
        "NSPhotoLibraryAddUsageDescription": "Souq Qalqilya needs permission to save images to your photo library when you download product photos from a listing you are viewing in the marketplace.",
        "NSUserNotificationsUsageDescription": "Souq Qalqilya sends you push notifications to alert you immediately when a buyer or seller sends you a new message about one of your marketplace listings, so you never miss a sale opportunity.",
        "NSMicrophoneUsageDescription": "Souq Qalqilya does not record audio or use the microphone for any feature. This permission entry is required by iOS because the camera framework used for capturing product photos includes microphone APIs. The microphone is never accessed by the app.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.onspace.souq_qalqilya",
      "versionCode": 6,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/plankton-logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "minSdkVersion": 29,
      "targetSdkVersion": 35,
      "compileSdkVersion": 35,
      "allowBackup": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.INTERNET",
        "android.permission.VIBRATE"
      ],
      "blockedPermissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.HIGH_SAMPLING_RATE_SENSORS",
        "android.permission.BODY_SENSORS",
        "android.permission.BODY_SENSORS_BACKGROUND",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.GET_ACCOUNTS",
        "android.permission.READ_PHONE_STATE",
        "android.permission.READ_PHONE_NUMBERS",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_CAMERA",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE",
        "android.permission.FOREGROUND_SERVICE_DATA_SYNC",
        "android.permission.FOREGROUND_SERVICE_HEALTH",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.MANAGE_EXTERNAL_STORAGE",
        "android.permission.PROCESS_OUTGOING_CALLS",
        "android.permission.SEND_SMS",
        "android.permission.RECEIVE_SMS",
        "android.permission.READ_SMS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "souqqalqilya",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "dmyjmmpytwppyfsjdmyj.backend.onspace.ai",
              "pathPrefix": "/auth/v1/callback"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/plankton-logo.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/withProductionManifest",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": false,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/plankton-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-camera",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "c102ae5b-583e-4af3-9643-7f32b9e5f1b1"
      }
    }
  }
}
